---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompanyCard from '../../components/CompanyCard.astro';
import { seoTexts, seoFallback } from '../../config/seoTexts.js';
import { branchenLabel, toOrtSlug } from '../../config/branchenLabels';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  const branchenMap = new Map<string, typeof companies>();
  for (const entry of companies) {
    for (const branche of entry.data.branchen) {
      if (!branchenMap.has(branche)) branchenMap.set(branche, []);
      branchenMap.get(branche)!.push(entry);
    }
  }
  return Array.from(branchenMap.entries()).map(([branche, entries]) => ({
    params: { branche },
    props:  { branche, companies: entries.map((e) => e.data) },
  }));
}

const { branche, companies } = Astro.props;
const orte = [...new Set(companies.map((c) => toOrtSlug(c.adresse.ort)))];
const brancheLabel = branchenLabel(branche);

const seoEntry = seoTexts[branche as keyof typeof seoTexts] ?? seoFallback;
const heroText = (seoEntry.heroText ?? seoFallback.heroText)
  .replace(/\{ort\}/g, 'der Alpenregion')
  .replace(/\{branche\}/g, brancheLabel);
---

<BaseLayout
  title={`${brancheLabel} in der Alpenregion – AlpenGewerbe`}
  description={`Alle ${brancheLabel}-Betriebe in der Schweiz und Liechtenstein. Kontakt, Bewertungen und Adressen auf AlpenGewerbe.`}
>
  <!-- Breadcrumb -->
  <nav class="bg-(--color-surface) border-b border-(--color-border)" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-1.5 text-sm text-(--color-text-muted)">
        <li><a href="/" class="hover:text-(--color-primary) transition-colors">AlpenGewerbe</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-(--color-text) font-medium" aria-current="page">{brancheLabel}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-(--color-section-dark) text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-white mb-3">{brancheLabel} in der Alpenregion</h1>
      <p class="text-white/80 text-base max-w-2xl mb-3">{heroText}</p>
      <p class="text-white/60 text-sm">
        {companies.length} {companies.length === 1 ? 'Betrieb' : 'Betriebe'} in der Schweiz und Liechtenstein
      </p>
    </div>
  </section>

  <!-- Regionale Filter -->
  {orte.length > 1 && (
    <section class="bg-(--color-surface-alt) border-b border-(--color-border) py-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-2">Nach Ort filtern</p>
        <div class="flex flex-wrap gap-2">
          <a href={`/${branche}/`}
             class="px-3 py-1.5 rounded-full text-sm font-medium bg-(--color-primary) text-white">
            Alle
          </a>
          {orte.map((ort) => (
            <a href={`/${branche}/${ort}/`}
               class="px-3 py-1.5 rounded-full text-sm font-medium bg-white border border-(--color-border)
                      text-(--color-text) hover:border-(--color-primary) hover:text-(--color-primary) transition-colors">
              {ort.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Betriebsliste -->
  <section class="py-10 lg:py-14 bg-[#F9FAFB]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
        {companies.map((company) => (
          <div class="animate-on-scroll">
            <CompanyCard
              name={company.name}
              slug={company.slug}
              branchen={company.branchen}
              ort={company.adresse.ort}
              plz={company.adresse.plz}
              land={company.adresse.land}
              rating={company.ratingCached?.rating}
              reviewCount={company.ratingCached?.user_ratings_total}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
