---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CompanyCard from '../../../components/CompanyCard.astro';

function toSlug(str: string) {
  return str.trim().toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/ä/g, 'ae').replace(/ö/g, 'oe').replace(/ü/g, 'ue')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

export async function getStaticPaths() {
  const companies = await getCollection('companies');

  function toSlug(str: string) {
    return str.trim().toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '')
      .replace(/ä/g, 'ae').replace(/ö/g, 'oe').replace(/ü/g, 'ue')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }

  // Ort → Einträge
  const ortMap = new Map<string, {
    label: string; land: 'CH' | 'LI';
    entries: typeof companies[0]['data'][];
  }>();

  for (const entry of companies) {
    const ort  = entry.data.adresse.ort?.trim();
    const land = entry.data.adresse.land;
    if (!ort) continue;
    const slug = toSlug(ort);
    const prev = ortMap.get(slug);
    if (prev) prev.entries.push(entry.data);
    else ortMap.set(slug, { label: ort, land, entries: [entry.data] });
  }

  const paths = [];

  for (const [ortSlug, { label: ortLabel, land, entries }] of ortMap) {
    const branchen = new Set<string>();
    for (const e of entries) {
      for (const b of e.branchen) branchen.add(b);
    }

    for (const branche of branchen) {
      const filtered = entries.filter(e => e.branchen.includes(branche));
      if (filtered.length === 0) continue;

      paths.push({
        params: { ort: ortSlug, branche },
        props:  { ortLabel, ortSlug, land, branche, companies: filtered },
      });
    }
  }

  return paths;
}

const { ortLabel, ortSlug, land, branche, companies } = Astro.props;
const brancheLabel = branche.charAt(0).toUpperCase() + branche.slice(1);
---

<BaseLayout
  title={`${brancheLabel} in ${ortLabel} – AlpenGewerbe`}
  description={`${companies.length} ${brancheLabel}-Betriebe in ${ortLabel}. Kontakt, Adressen und Bewertungen auf AlpenGewerbe.`}
>
  <nav class="bg-(--color-surface) border-b border-(--color-border)" aria-label="Breadcrumb">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5">
      <ol class="flex items-center gap-1.5 text-sm text-(--color-text-muted)">
        <li><a href="/" class="hover:text-(--color-primary) transition-colors">AlpenGewerbe</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={`/region/${ortSlug}/`} class="hover:text-(--color-primary) transition-colors">{ortLabel}</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-(--color-text) font-medium capitalize">{branche}</li>
      </ol>
    </div>
  </nav>

  <section class="bg-(--color-section-dark) text-white py-12 lg:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-2 mb-3 text-white/60 text-sm font-medium">
        <span class="text-xl">{land === 'LI' ? '🇱🇮' : '🇨🇭'}</span>
        <span>{ortLabel}</span>
        <span aria-hidden="true">›</span>
        <span class="capitalize">{branche}</span>
      </div>
      <h1 class="text-white mb-3">{brancheLabel} in {ortLabel}</h1>
      <p class="text-white/70 text-lg max-w-xl">
        {companies.length} {companies.length === 1 ? 'Betrieb' : 'Betriebe'} gefunden.
      </p>
    </div>
  </section>

  <!-- Zurück-Link zur Ortsseite -->
  <section class="bg-(--color-surface-alt) border-b border-(--color-border) py-3">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center gap-3">
      <a href={`/region/${ortSlug}/`}
         class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium
                bg-white border border-(--color-border) text-(--color-text)
                hover:border-(--color-primary) hover:text-(--color-primary) transition-colors">
        ← Alle Branchen in {ortLabel}
      </a>
      <a href={`/${branche}/`}
         class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium
                bg-white border border-(--color-border) text-(--color-text)
                hover:border-(--color-primary) hover:text-(--color-primary) transition-colors capitalize">
        Alle {branche} in der Schweiz
      </a>
    </div>
  </section>

  <section class="py-10 lg:py-14 bg-[#F9FAFB]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
        {companies.map((company) => (
          <div class="animate-on-scroll">
            <CompanyCard
              name={company.name}
              slug={company.slug}
              branchen={company.branchen}
              ort={company.adresse.ort}
              plz={company.adresse.plz}
              land={company.adresse.land}
              rating={company.ratingCached?.rating}
              reviewCount={company.ratingCached?.user_ratings_total}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
