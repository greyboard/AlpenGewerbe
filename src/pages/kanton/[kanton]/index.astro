---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CompanyCard from '../../../components/CompanyCard.astro';
import { CH_KANTONE } from '../../../data/kantone';

export async function getStaticPaths() {
  const { CH_KANTONE } = await import('../../../data/kantone');
  const companies = await getCollection('companies');

  return CH_KANTONE.map(({ name, kürzel, slug }) => {
    const kantonCompanies = companies
      .filter(e => (e.data.adresse as any).kanton === name)
      .map(e => e.data);

    return {
      params: { kanton: slug },
      props:  { kantonName: name, kürzel, companies: kantonCompanies },
    };
  });
}

const { kantonName, kürzel, companies } = Astro.props;

// Branchen in diesem Kanton
const branchenCount = new Map<string, number>();
for (const c of companies) {
  for (const b of c.branchen) {
    branchenCount.set(b, (branchenCount.get(b) ?? 0) + 1);
  }
}
const topBranchen = [...branchenCount.entries()].sort((a, b) => b[1] - a[1]);

// Top-Städte in diesem Kanton
const orteCount = new Map<string, number>();
for (const c of companies) {
  const ort = c.adresse.ort?.trim();
  if (ort) orteCount.set(ort, (orteCount.get(ort) ?? 0) + 1);
}
const topOrte = [...orteCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, 10);

function ortSlug(ort: string) {
  return ort.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/ä/g, 'ae').replace(/ö/g, 'oe').replace(/ü/g, 'ue')
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}
---

<BaseLayout
  title={`Handwerker Kanton ${kantonName} (${kürzel}) – AlpenGewerbe`}
  description={`${companies.length} Handwerksbetriebe im Kanton ${kantonName}. Schreiner, Elektriker, Maler und mehr auf AlpenGewerbe.`}
>
  <!-- Breadcrumb -->
  <nav class="bg-(--color-surface) border-b border-(--color-border)" aria-label="Breadcrumb">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5">
      <ol class="flex items-center gap-1.5 text-sm text-(--color-text-muted)">
        <li><a href="/" class="hover:text-(--color-primary) transition-colors">AlpenGewerbe</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/" class="hover:text-(--color-primary) transition-colors">🇨🇭 Schweiz</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-(--color-text) font-medium">{kantonName}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-(--color-section-dark) text-white py-12 lg:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-flex items-center justify-center text-sm font-bold text-white/80
                     bg-white/15 px-2.5 py-1 rounded-lg tracking-wider">
          {kürzel}
        </span>
        <h1 class="text-white">Handwerker Kanton {kantonName}</h1>
      </div>
      <p class="text-white/70 text-lg max-w-xl">
        {companies.length} {companies.length === 1 ? 'Betrieb' : 'Betriebe'} im Kanton {kantonName}.
      </p>

      {topBranchen.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {topBranchen.slice(0, 7).map(([branche, count]) => (
            <a href={`/kanton/${Astro.params.kanton}/${branche}/`}
               class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white/80
                      text-sm font-medium hover:bg-white/20 transition-colors capitalize">
              {branche}
              <span class="text-white/50 text-xs">{count}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Filter: Branchen + Städte -->
  {(topBranchen.length > 1 || topOrte.length > 1) && (
    <section class="bg-(--color-surface-alt) border-b border-(--color-border) py-4">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-wrap gap-x-8 gap-y-3">
        {topBranchen.length > 1 && (
          <div>
            <p class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1.5">Branche</p>
            <div class="flex flex-wrap gap-1.5">
              {topBranchen.map(([branche, count]) => (
                <a href={`/kanton/${Astro.params.kanton}/${branche}/`}
                   class="px-2.5 py-1 rounded-full text-xs font-medium bg-white border border-(--color-border)
                          text-(--color-text) hover:border-(--color-primary) hover:text-(--color-primary) transition-colors capitalize">
                  {branche} ({count})
                </a>
              ))}
            </div>
          </div>
        )}
        {topOrte.length > 1 && (
          <div>
            <p class="text-xs font-semibold text-(--color-text-muted) uppercase tracking-wider mb-1.5">Stadt</p>
            <div class="flex flex-wrap gap-1.5">
              {topOrte.map(([ort, count]) => (
                <a href={`/region/${ortSlug(ort)}/`}
                   class="px-2.5 py-1 rounded-full text-xs font-medium bg-white border border-(--color-border)
                          text-(--color-text) hover:border-(--color-primary) hover:text-(--color-primary) transition-colors">
                  {ort} ({count})
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Betriebsliste -->
  <section class="py-10 lg:py-14 bg-[#F9FAFB]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      {companies.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
          {companies.map((company) => (
            <div class="animate-on-scroll">
              <CompanyCard
                name={company.name}
                slug={company.slug}
                branchen={company.branchen}
                ort={company.adresse.ort}
                plz={company.adresse.plz}
                land={company.adresse.land}
                rating={company.ratingCached?.rating}
                reviewCount={company.ratingCached?.user_ratings_total}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-(--color-text-muted) text-center py-16">
          Noch keine Betriebe für Kanton {kantonName} eingetragen.
        </p>
      )}
    </div>
  </section>

</BaseLayout>
