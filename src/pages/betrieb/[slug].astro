---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LocalBusinessSchema from '../../components/LocalBusinessSchema.astro';
import { branchenLabel } from '../../config/branchenLabels';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((entry) => ({
    params: { slug: entry.data.slug },
    props:  { company: entry.data },
  }));
}

const { company } = Astro.props;
const {
  name, slug, branchen, adresse, kontakt, ratingCached,
  description, accountStatus, leistungen, openingHours, googlePlaceId,
} = company;

// Sterne-Render-Helfer
function stars(rating: number): string {
  const full  = Math.floor(rating);
  const half  = rating % 1 >= 0.5;
  const empty = 5 - full - (half ? 1 : 0);
  return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(empty);
}

// Initialen aus Autorenname (immer 2 Zeichen)
function getInitials(authorName: string): string {
  const parts = authorName.trim().split(/\s+/);
  if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
  return authorName.slice(0, 2).toUpperCase();
}

// Deterministische Avatarfarbe basierend auf Char-Code-Summe des Namens
function getAvatarColor(authorName: string): string {
  const palette = ['#6366F1', '#0D9488', '#D97706', '#059669', '#7C3AED', '#0284C7', '#BE185D', '#B45309'];
  const sum = authorName.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);
  return palette[sum % palette.length];
}

// Paywall: "Über den Betrieb" nur für bezahlte Accounts sichtbar
const showDescription = description && (accountStatus === 'business' || accountStatus === 'premium');
---

<BaseLayout
  title={`${name} – ${branchen[0] ?? 'Gewerbe'} in ${adresse.ort} | AlpenGewerbe`}
  description={`${name} in ${adresse.ort} (${adresse.plz}). Kontakt, Bewertungen und Informationen auf AlpenGewerbe.`}
>
  <slot slot="head" name="head">
    <LocalBusinessSchema
      name={name}
      slug={slug}
      branchen={branchen}
      adresse={adresse}
      kontakt={kontakt}
      ratingCached={ratingCached}
    />
  </slot>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────── -->
  <nav class="bg-(--color-surface) border-b border-(--color-border)" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-1.5 text-sm text-(--color-text-muted)" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item" class="hover:text-(--color-primary) transition-colors">
            <span itemprop="name">AlpenGewerbe</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li aria-hidden="true">›</li>
        {branchen[0] && (
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href={`/${branchen[0]}/`} itemprop="item" class="hover:text-(--color-primary) transition-colors">
              <span itemprop="name">{branchenLabel(branchen[0])}</span>
            </a>
            <meta itemprop="position" content="2" />
          </li>
          <li aria-hidden="true">›</li>
        )}
        <li class="text-(--color-text) font-medium truncate max-w-[200px]" aria-current="page">{name}</li>
      </ol>
    </div>
  </nav>

  <!-- ── Hero / Header ──────────────────────────────────────────────── -->
  <section class="bg-white border-b border-(--color-border) py-10 lg:py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-[1.4fr_0.6fr] gap-8 items-start">

      <!-- Links: Name + Meta -->
      <div>
        <!-- Branchen-Badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          {branchen.map((b) => (
            <a
              href={`/${b}/`}
              class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-(--color-surface-alt)
                     text-(--color-primary-text) hover:bg-(--color-primary) hover:text-white transition-colors"
            >
              {branchenLabel(b)}
            </a>
          ))}
        </div>

        <h1 class="mb-3">{name}</h1>

        <!-- Standort -->
        <p class="flex items-center gap-2 text-(--color-text-muted) mb-4">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          {adresse.strasse}, {adresse.plz} {adresse.ort} &middot; {adresse.land === 'CH' ? '🇨🇭 Schweiz' : '🇱🇮 Liechtenstein'}
        </p>

        <!-- Google-Rating -->
        {ratingCached && ratingCached.user_ratings_total > 0 && (
          <div class="flex items-center gap-3">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="font-bold text-(--color-text) text-lg">{ratingCached.rating.toFixed(1)}</span>
            <span class="text-[#FBBC05] text-lg leading-none" aria-hidden="true">{stars(ratingCached.rating)}</span>
            <span class="text-(--color-text-muted) text-sm">({ratingCached.user_ratings_total} Bewertungen auf Google)</span>
          </div>
        )}
      </div>

      <!-- Rechts: Kontakt-Card -->
      <div class="bg-(--color-surface) border border-(--color-border) rounded-xl p-6 space-y-4">
        <h2 class="text-base font-semibold text-(--color-text) mb-3">Kontakt</h2>

        {kontakt.telefon && (
          <a href={`tel:${kontakt.telefon.replace(/\s/g, '')}`}
             class="flex items-center gap-3 text-sm text-(--color-text) hover:text-(--color-primary) transition-colors group">
            <span class="w-8 h-8 rounded-lg bg-(--color-primary)/10 flex items-center justify-center flex-shrink-0 group-hover:bg-(--color-primary)/20 transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </span>
            {kontakt.telefon}
          </a>
        )}

        {kontakt.email && (
          <a href={`mailto:${kontakt.email}`}
             class="flex items-center gap-3 text-sm text-(--color-text) hover:text-(--color-primary) transition-colors group">
            <span class="w-8 h-8 rounded-lg bg-(--color-primary)/10 flex items-center justify-center flex-shrink-0 group-hover:bg-(--color-primary)/20 transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            {kontakt.email}
          </a>
        )}

        {kontakt.webseite && (
          <a href={kontakt.webseite} target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-3 text-sm text-(--color-text) hover:text-(--color-primary) transition-colors group">
            <span class="w-8 h-8 rounded-lg bg-(--color-primary)/10 flex items-center justify-center flex-shrink-0 group-hover:bg-(--color-primary)/20 transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </span>
            <span class="truncate">{kontakt.webseite.replace(/^https?:\/\//, '')}</span>
          </a>
        )}
      </div>

    </div>
  </section>

  <!-- ── Beschreibung / Paywall ───────────────────────────────────── -->
  <section class="py-8 bg-white border-b border-(--color-border)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {showDescription ? (
        <>
          <h2 class="text-xl font-semibold mb-3">Über den Betrieb</h2>
          <p class="text-(--color-text-muted) leading-relaxed">{description}</p>
        </>
      ) : (
        <div class="rounded-xl border border-dashed border-(--color-border) bg-(--color-surface) p-6 flex flex-col sm:flex-row items-start sm:items-center gap-5">
          <div class="flex-1">
            <p class="text-(--color-text-muted) text-sm leading-relaxed mb-3">
              Für diesen Eintrag wurden noch keine erweiterten Betriebsinformationen hinterlegt.
              Sind Sie der Inhaber? Jetzt Eintrag kostenlos verifizieren.
            </p>
            <a
              href={`/claim/${slug}`}
              class="inline-flex items-center gap-2 bg-(--color-primary) text-white px-5 py-2.5 rounded-lg
                     text-sm font-semibold transition-all duration-200 hover:shadow-md hover:scale-[1.02]"
            >
              Eintrag beanspruchen
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
          <div class="hidden sm:flex w-14 h-14 rounded-full bg-(--color-primary)/10 items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-(--color-primary)" aria-hidden="true">
              <path d="M9 12h6M12 9v6M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
            </svg>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── Leistungen + Öffnungszeiten ───────────────────────────────── -->
  {(leistungen?.length || openingHours?.length) && (
    <section class="py-8 bg-(--color-surface-alt) border-b border-(--color-border)">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid sm:grid-cols-2 gap-8">

        {leistungen?.length && (
          <div>
            <h2 class="text-xl font-semibold mb-4">Leistungen</h2>
            <ul class="space-y-2">
              {leistungen.map(l => (
                <li class="flex items-center gap-2.5 text-sm text-(--color-text)">
                  <svg class="w-4 h-4 text-(--color-primary) flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  {l}
                </li>
              ))}
            </ul>
          </div>
        )}

        {openingHours?.length && (
          <div>
            <h2 class="text-xl font-semibold mb-4">Öffnungszeiten</h2>
            <ul class="space-y-1.5">
              {openingHours.map(day => {
                const [wochentag, zeit] = day.split(': ');
                const geschlossen = zeit?.toLowerCase().includes('geschlossen');
                return (
                  <li class="flex justify-between text-sm">
                    <span class="text-(--color-text-muted) w-28">{wochentag}</span>
                    <span class={geschlossen ? 'text-(--color-text-muted) italic' : 'text-(--color-text) font-medium'}>
                      {zeit}
                    </span>
                  </li>
                );
              })}
            </ul>
            {googlePlaceId && (
              <a
                href={`https://www.google.com/maps/place/?q=place_id:${googlePlaceId}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-4 text-xs text-(--color-text-muted) hover:text-(--color-primary) transition-colors"
              >
                <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Auf Google Maps ansehen
              </a>
            )}
          </div>
        )}

      </div>
    </section>
  )}

  <!-- ── Google-Bewertungen ─────────────────────────────────────────── -->
  {ratingCached && ratingCached.reviews.length > 0 && (
    <section class="py-12 lg:py-16 bg-(--color-surface-alt)">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="mb-2 animate-on-scroll">Kundenbewertungen</h2>
        <p class="text-(--color-text-muted) mb-8 animate-on-scroll">
          {ratingCached.user_ratings_total} Bewertungen auf Google &middot; Ø {ratingCached.rating.toFixed(1)} von 5 Sternen
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
          {ratingCached.reviews.map((review, i) => (
            <article class="bg-white border border-(--color-border) rounded-xl p-5 animate-on-scroll
                            transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
              <!-- Reviewer -->
              <div class="flex items-center gap-3 mb-3">
                <div
                  class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-semibold flex-shrink-0 select-none"
                  style={`background-color: ${getAvatarColor(review.author_name)}`}
                  aria-hidden="true"
                >
                  {getInitials(review.author_name)}
                </div>
                <div>
                  <p class="text-sm font-semibold text-(--color-text) leading-tight">{review.author_name}</p>
                  {review.relative_time_description && (
                    <p class="text-xs text-(--color-text-muted)">{review.relative_time_description}</p>
                  )}
                </div>
                <!-- Google G -->
                <svg viewBox="0 0 24 24" width="18" height="18" class="ml-auto flex-shrink-0" aria-label="Google-Bewertung">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>

              <!-- Sterne -->
              <div role="img" aria-label={`${review.rating} von 5 Sternen`} class="text-[#FBBC05] mb-2 text-sm">
                {'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}
              </div>

              <!-- Text -->
              <p class="text-sm text-(--color-text-muted) leading-relaxed line-clamp-4">{review.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── CTA ───────────────────────────────────────────────────────── -->
  <section class="py-12 bg-(--color-primary)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-5">
      <p class="text-white text-lg font-semibold">Ist das Ihr Betrieb? Daten aktualisieren oder Eintrag verwalten.</p>
      <a href="/betrieb/eintragen/"
         class="inline-flex items-center gap-2 bg-white text-(--color-primary-text) px-6 py-3 rounded-lg font-semibold text-sm
                transition-all duration-200 hover:shadow-lg hover:scale-[1.02] whitespace-nowrap">
        Eintrag verwalten
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
