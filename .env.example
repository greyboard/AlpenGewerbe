# Site-Domain (wird in astro.config.mjs und Sitemap verwendet)
# Cloudflare Pages: Unter Settings > Environment Variables setzen
PUBLIC_SITE_URL=https://alpengewerbe.io

# Google Places API Key (für scripts/sync-google.js)
# Benötigt: Places API (New) aktiviert in der Google Cloud Console
GOOGLE_PLACES_API_KEY=your_api_key_here
